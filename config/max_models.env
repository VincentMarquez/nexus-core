# Max-tier models for multi-vendor NEXUS bus (source before nexus start)
# ChatGPT / Codex (adversary + hard review)
export NEXUS_CODEX_MODEL=gpt-5.6-sol
export NEXUS_CODEX_REASONING=ultra
export NEXUS_CODEX_SERVICE_TIER=fast

# Claude (plan + review L1)
export NEXUS_CLAUDE_MODEL=fable
export NEXUS_CLAUDE_EFFORT=max

# Grok (implementer)
export NEXUS_GROK_MODEL=grok-4.5
export NEXUS_GROK_REASONING_EFFORT=max
export NEXUS_GROK_BRIDGE_TURNS=12

# Gemini (research) — leave empty for CLI default; set if you pin a top Gemini
# export NEXUS_GEMINI_MODEL=

# Timeouts for heavy max models
export NEXUS_CLI_TIMEOUT_S=600
export NEXUS_MSG_TIMEOUT_MS=600000
