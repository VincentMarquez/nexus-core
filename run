#!/usr/bin/env bash
# Zero-config entrypoint:
#   ./run                              → start stack + agents
#   ./run https://github.com/org/repo  → start stack, then clone/install/fix that repo
#   ./run owner/repo --goal "…"
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

echo "=== NEXUS Core — auto start ==="
echo "  repo: $ROOT"
echo

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required (3.10+)."
  exit 1
fi

if ! command -v node >/dev/null 2>&1; then
  echo "ERROR: Node.js 18+ is required for the dashboard/event bus."
  echo "  Install: https://nodejs.org  then re-run ./run"
  exit 1
fi

if [[ ! -d .venv ]]; then
  echo "→ creating Python venv (.venv)…"
  python3 -m venv .venv
fi

# shellcheck disable=SC1091
source .venv/bin/activate

echo "→ installing / updating package…"
python -m pip install -q -U pip
python -m pip install -q -e .

# If first arg looks like a GitHub URL / owner/repo → nexus do
if [[ $# -ge 1 ]]; then
  arg1="${1:-}"
  if [[ "$arg1" == *github.com* ]] \
    || [[ "$arg1" == git@github.com:* ]] \
    || [[ "$arg1" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
    echo "→ GitHub target detected — clone / install / run / fix"
    exec nexus do "$@"
  fi
fi

# Default: fully automatic stack start
exec nexus start --yes "$@"
