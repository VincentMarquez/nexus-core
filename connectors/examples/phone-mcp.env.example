# Copy to your shell profile or a local .env that is gitignored.
# Personal memory MCP on a phone/pocket device (optional).

PHONE_MCP_URL=https://<your-auth-tunnel>/mcp
# Fallback when the public tunnel is down (private mesh / tailnet):
PHONE_MCP_TAILNET_URL=http://<phone-on-private-network>:<port>/mcp

# Client behavior:
# - treat as best-effort
# - on connection error → empty context, do not fail the task
