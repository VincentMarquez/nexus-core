{
  "mcpServers": {
    "nexus-workspace": {
      "command": "/path/to/nexus-core/.venv/bin/python",
      "args": [
        "-m",
        "nexus.mcp_server"
      ],
      "env": {
        "NEXUS_PROJECT_ROOT": "/path/to/nexus-core",
        "PYTHONPATH": "/path/to/nexus-core/src"
      }
    }
  }
}
